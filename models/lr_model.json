{
  "version": "2.0.0",
  "model": "logistic_regression_light",
  "chapter": "2",
  "target": "probability_mastered",
  "notes": "All numeric features are normalized before applying weights. time_spent_sec is capped and divided by 300 seconds.",
  "features": [
    "difficulty",
    "attempts_count",
    "used_help",
    "time_spent_sec",
    "showed_solution",
    "bkt_mastery"
  ],
  "normalization": {
    "difficulty": {
      "easy": -1,
      "medium": 0,
      "hard": 1,
      "سهل": -1,
      "متوسط": 0,
      "صعب": 1
    },
    "attempts_count": {
      "type": "scaled",
      "formula": "min(max((attempts_count - 1) / 3, 0), 1)"
    },
    "used_help": {
      "type": "binary"
    },
    "time_spent_sec": {
      "type": "scaled",
      "formula": "min(max(time_spent_sec / 300, 0), 1)"
    },
    "showed_solution": {
      "type": "binary"
    },
    "bkt_mastery": {
      "type": "probability",
      "min": 0,
      "max": 1
    }
  },
  "weights": {
    "bias": -1.1,
    "difficulty": -0.35,
    "attempts_count": -0.45,
    "used_help": -0.25,
    "time_spent_sec": -0.1,
    "showed_solution": -0.65,
    "bkt_mastery": 3.2
  },
  "support_thresholds": {
    "none": 0.75,
    "hint": 0.5,
    "guided_steps": 0.0
  }
}